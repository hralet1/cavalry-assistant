# Cavalry Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# ── Cavalry Stallion bridge ──────────────────────────────────────────────────
CAVALRY_HOST=127.0.0.1:8080

# ── Database ─────────────────────────────────────────────────────────────────
DB_BACKEND=local

# LanceDB path — MUST be on a local drive (atomic rename fails on network drives)
# For regular use: download the public DB from GitHub Releases and point here.
# For contributors: point to your private DB after running ETL.
LANCEDB_PATH=./data/lancedb_public

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBED_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434

# Optional: OpenAI instead of Ollama
# EMBED_BACKEND=openai
# OPENAI_API_KEY=sk-...

# ── Optional: Supabase (hosted DB backend) ───────────────────────────────────
# SUPABASE_URL=
# SUPABASE_KEY=

# ── Optional: scene info output path ─────────────────────────────────────────
SCENE_INFO_PATH=cavalry_scene_info.json

# ── Private ETL — only needed if rebuilding the knowledge base ───────────────
# Discord bot token (for ingesting Cavalry Discord community Q&A)
DISCORD_TOKEN=
DISCORD_CHANNEL_IDS=

# Scenery.io session cookie (for scraping .cv scene files)
# Get from browser DevTools → Network tab → authorization header after login
SCENERY_COOKIE=

# Copy this file to .env and fill in your values. Never commit .env.

# Cavalry Stallion bridge (default: localhost:8080)
CAVALRY_HOST=127.0.0.1:8080

# Database backend: "local" (LanceDB, default) or "supabase"
DB_BACKEND=local

# LanceDB path (relative to project root)
LANCEDB_PATH=./data/lancedb

# Ollama host (default: local Docker or localhost)
OLLAMA_HOST=http://localhost:11434

# Embedding backend: "ollama" (default, no API key) or "openai"
EMBED_BACKEND=ollama

# Optional: OpenAI API key (only if EMBED_BACKEND=openai)
OPENAI_API_KEY=

# Optional: Supabase (only if DB_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# Optional: where get_scene_info writes its output
SCENE_INFO_PATH=cavalry_scene_info.json

# Discord export — for ETL ingestion only, not needed for normal use
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=
# Comma-separated channel IDs to export (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_IDS=

# Scenery.io cookie — for scraping example files, not needed for normal use
# Get from browser DevTools after logging into scenery.io
SCENERY_COOKIE=
